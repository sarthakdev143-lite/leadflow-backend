# Copy to .env and fill real values. NEVER commit .env to git.

# MongoDB Atlas example:
# MONGO_URL=mongodb+srv://<username>:<password>@<cluster-url>/leadflow_db
# Local Docker MongoDB example:
# MONGO_URL=mongodb://admin:secret@mongo:27017/leadflow_db?authSource=admin
MONGO_URL=mongodb://admin:secret@mongo:27017/leadflow_db?authSource=admin

NGINX_PORT=80

MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=secret
MONGO_INITDB_DATABASE=leadflow_db

JWT_SECRET_TOKEN=replace-with-a-long-random-secret-that-is-more-than-sixty-four-characters-1234567890
JWT_EXPIRATION_TIME=604800000

MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

FRONTEND_URL=http://localhost:3000

WHATSAPP_ACCOUNT_ID=your-twilio-account-sid
WHATSAPP_AUTH_TOKEN=your-twilio-auth-token
WHATSAPP_NUMBER=whatsapp:+14155238886
